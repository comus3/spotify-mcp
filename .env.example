PORT=3000

# Spotify Developer Dashboard → your app → Client ID
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Must exactly match a Redirect URI registered on the same Spotify app.
# Local dev (Spotify allows http://localhost):
#   SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
# Production (HTTPS required by Spotify for non-localhost):
#   SPOTIFY_REDIRECT_URI=https://your-domain.example/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Optional: if set, clients must send this value as header X-Mcp-Secret or query ?secret=
MCP_SECRET=

# Optional (Docker): timezone for the container
# TZ=UTC
